# Set this to the branch name you have checked out locally
# The application will log this at startup
# Examples: BRANCH=main or BRANCH=develop
BRANCH=main

# JWT signing key. REQUIRED in production; for local development prefer
# `dotnet user-secrets set "Jwt:Key" ...` over committing to .env.
# Use a high-entropy value (e.g. `openssl rand -base64 32`).
Jwt__Key=

# Comma-separated admin email addresses (case-insensitive).
# Users with these emails are automatically assigned the Admin role on login/register.
# Example: AdminEmails=alice@example.com,bob@example.com
AdminEmails=

# Docker image tag to pull from ghcr.io/scevola44/wwn_charactersheet
# Run: docker compose pull && docker compose up -d
# Defaults to 'latest' if not specified
# Available tags:
#   latest      : Latest production release (main branch)
#   beta        : Latest beta build (develop branch)
#   sha-<hash>  : Specific commit SHA
#   v1.0.0      : Specific semantic version release
IMAGE_TAG=latest

# Docker container HTTP port (mapped from inside the container)
ASPNETCORE_HTTP_PORTS=5000

# Database connection string
# The /app/db volume is mounted from ./data on the host
ConnectionStrings__Default=Data Source=/app/db/wwn_characters.db

# Data protection keys path (where EF Core stores encryption keys)
# Must match the volume mount path
DataProtection__KeysPath=/app/db/keys

# Public base URL of the frontend, used to build confirmation/reset links inside emails.
# Example: AppUrls__WebBaseUrl=https://wwn.example.com
# Local dev (Vite default): http://localhost:5173
AppUrls__WebBaseUrl=http://localhost:5173

# SMTP settings for outbound mail (account confirmation, password reset).
# Local dev tip: run MailHog (`docker run -p 1025:1025 -p 8025:8025 mailhog/mailhog`)
# and leave Host=localhost / Port=1025 / EnableSsl=false / no credentials.
#
# Port choice (EnableSsl=true):
#   465 → implicit TLS/SMTPS (recommended — rarely blocked by hosting providers)
#   587 → explicit TLS/STARTTLS (often blocked on VPS/cloud outbound firewall)
# iCloud example: smtp.mail.me.com / Port=465 / EnableSsl=true
Email__Smtp__Host=localhost
Email__Smtp__Port=1025
Email__Smtp__EnableSsl=false
Email__Smtp__Username=
Email__Smtp__Password=
Email__Smtp__FromAddress=no-reply@wwn-charactersheet.local
Email__Smtp__FromName=WWN Character Sheet
