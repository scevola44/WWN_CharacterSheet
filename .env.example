# Set this to the branch name you have checked out locally
# The application will log this at startup
# Examples: BRANCH=main or BRANCH=develop
BRANCH=main

# JWT signing key. REQUIRED in production; for local development prefer
# `dotnet user-secrets set "Jwt:Key" ...` over committing to .env.
# Use a high-entropy value (e.g. `openssl rand -base64 32`).
Jwt__Key=

# Docker image to pull for production deploys instead of building from source.
# Run: docker compose pull && docker compose up -d
# Leave blank (or omit) to build locally from the Dockerfile.
# Examples:
#   IMAGE_TAG=ghcr.io/scevola44/wwn_charactersheet:latest
#   IMAGE_TAG=ghcr.io/scevola44/wwn_charactersheet:beta
#   IMAGE_TAG=ghcr.io/scevola44/wwn_charactersheet:sha-a1b2c3d
IMAGE_TAG=
