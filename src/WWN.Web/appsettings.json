{
  "Version": {
    "Branch": "main",
    "Base": "1.1"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/wwn-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=wwn_characters.db"
  },
  "Jwt": {
    "Issuer": "WWNCharacterSheet",
    "Audience": "WWNCharacterSheetUsers"
  },
  "AdminEmails": ""
}
