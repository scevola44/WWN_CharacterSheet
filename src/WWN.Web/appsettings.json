{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/wwn-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=wwn_characters.db"
  },
  "Jwt": {
    "Key": "wwn-character-sheet-dev-secret-key-change-in-production",
    "Issuer": "WWNCharacterSheet",
    "Audience": "WWNCharacterSheetUsers"
  }
}
